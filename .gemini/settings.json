{
  "mcpServers": {
    "context7": {
      "args": [],
      "command": "context7-mcp",
      "env": {},
      "type": "stdio"
    },
    "git": {
      "args": [],
      "command": "mcp-server-git",
      "env": {},
      "type": "stdio"
    },
    "playwright": {
      "args": [],
      "command": "mcp-server-playwright",
      "env": {},
      "type": "stdio"
    },
    "serena": {
      "args": [
        "start-mcp-server",
        "--context",
        "ide-assistant",
        "--enable-web-dashboard",
        "false",
        "--project",
        "."
      ],
      "command": "serena",
      "env": {},
      "type": "stdio"
    }
  },
  "hooks": {
    "AfterTool": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "$GEMINI_PROJECT_DIR/scripts/format"
          },
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path' | { read -r f; git add \"$f\"; } 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
