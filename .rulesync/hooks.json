{
    "version": 1,
    "hooks": {
        "postToolUse": [
            {
                "type": "command",
                "command": "./scripts/format",
                "matcher": "Edit|Write"
            },
            {
                "type": "command",
                "command": "jq -r '.tool_input.file_path' | { read -r f; git add \"$f\"; } 2>/dev/null || true",
                "matcher": "Edit|Write"
            }
        ]
    }
}
