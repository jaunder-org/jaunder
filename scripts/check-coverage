#!/usr/bin/env bash
# Check that source-line coverage has not dropped below the committed
# baseline per file.
#
# Usage:
#   scripts/check-coverage             — run tests, check growth, fail on regression
#   scripts/check-coverage --update    — force update manifest (be careful)
#   scripts/check-coverage --investigate — re-analyze last reports without re-running tests
#
# Coverage metric: We parse `cargo llvm-cov report --text` per-file output and
# count source lines with at least one execution. This is the true source-line
# coverage. We deliberately do NOT use `summary.lines.percent` from
# `cargo llvm-cov nextest --json`, because that count is inflated by
# per-compile-unit instantiations: a generic function compiled once for the
# `web` lib-test binary and once for the `jaunder` integration-test binary
# contributes its instantiation counters twice, and tests that exercise the
# integration-test instantiation leave the lib-test instantiation unhit even
# though every source line is covered.
#
# The manifest is stored in .coverage-manifest.json and should be committed.
set -euo pipefail

ROOT="$(git rev-parse --show-toplevel 2>/dev/null || echo ".")"
MANIFEST_FILE="$ROOT/.coverage-manifest.json"
REPORT_FILE="$ROOT/.coverage-report.txt"
LCOV_FILE="$ROOT/.coverage-report.lcov"
CRAP_MANIFEST_FILE="$ROOT/.crap-manifest.json"
CRAP_REPORT_FILE="$ROOT/.crap-report.json"
UPDATE=false
INVESTIGATE=false
CHECK=false
EMIT=false

for arg in "$@"; do
    case "$arg" in
        --update) UPDATE=true ;;
        --investigate) INVESTIGATE=true ;;
        --check) CHECK=true ;;
        --emit) EMIT=true ;;
        *) echo "error: unknown argument: $arg" >&2; exit 1 ;;
    esac
done

cd "$ROOT"
ABS_ROOT="$(pwd)"

normalize_crap_report() {
    local input="$1"
    local output="$2"

    jq --arg root "$ABS_ROOT/" '
        .entries |= map(.file |= (if startswith($root) then .[($root | length):] else . end))
    ' "$input" > "$output"
}

if [[ "$INVESTIGATE" == "true" ]]; then
    if [[ ! -f "$REPORT_FILE" ]]; then
        echo "error: no coverage report found at $REPORT_FILE. Run without --investigate first." >&2
        exit 1
    fi
    if [[ ! -f "$CRAP_REPORT_FILE" ]]; then
        echo "error: no CRAP report found at $CRAP_REPORT_FILE. Run without --investigate first." >&2
        exit 1
    fi
    echo "--- coverage: investigating cached reports ---"
else
    # Coverage is collected in two passes that accumulate profraw data, then a
    # single merged report. The default pass runs the whole suite against
    # SQLite; the second pass re-runs the jaunder integration tests against a
    # throwaway host PostgreSQL so that storage/src/postgres/* (only reachable
    # with a live PG server) gets instrumented coverage too. Line coverage is a
    # union of hits, so PG-only lines flip to covered while shared lines stay
    # covered — no double-counting.
    # Clear only stale profraw (coverage data) from a previous run, NOT the
    # instrumented build — `clean --workspace` would force a ~270s recompile
    # every run; `--profraw-only` keeps the cached instrumented binaries (which
    # live in a separate target dir), cutting repeat runs from ~530s to ~90s.
    echo "--- coverage: clearing stale profraw (keeping instrumented build) ---"
    cargo llvm-cov clean --profraw-only

    echo "--- coverage: running cargo llvm-cov (SQLite pass) ---"
    cargo llvm-cov --no-report nextest --show-progress none

    echo "--- coverage: running cargo llvm-cov (PostgreSQL pass) ---"
    # Invoke via `bash` rather than relying on the script's shebang: the Nix
    # build sandbox (used by the `coverage` flake check) has no /usr/bin/env.
    bash scripts/with-ephemeral-postgres \
        cargo llvm-cov --no-report nextest --show-progress none \
        -p jaunder --run-ignored all

    echo "--- coverage: building merged text report ---"
    cargo llvm-cov report --text > "$REPORT_FILE"

    # Reuse the just-recorded llvm-cov profraw data to export LCOV for
    # cargo-crap. Do not run `cargo llvm-cov --lcov` here: that would execute
    # the test suite a second time.
    echo "--- coverage: exporting LCOV for cargo-crap ---"
    cargo llvm-cov report --lcov --output-path "$LCOV_FILE" > /dev/null

    echo "--- coverage: running cargo-crap ---"
    RAW_CRAP_REPORT=$(mktemp)
    cargo crap --workspace --lcov "$LCOV_FILE" --exclude '**/tests/**' --format json --output "$RAW_CRAP_REPORT" > /dev/null
    normalize_crap_report "$RAW_CRAP_REPORT" "$CRAP_REPORT_FILE"
fi

# Produce-only mode: the two instrumented passes have run and the rich report,
# LCOV, and CRAP report are all on disk. Exit before the coverage/CRAP
# regression gating — that gate now lives in host xtask. Test failures still
# abort earlier under `set -e` (the `cargo llvm-cov nextest` passes).
if [[ "$EMIT" == "true" ]]; then
    echo "--- coverage: emit mode — report + CRAP produced, skipping regression gate ---"
    exit 0
fi

# Parse the per-file text output into a JSON object mapping relative-path → percent.
# A source line is "executable" if its second pipe-separated column is a number
# (e.g. `0`, `86`, `1.36k`). A line whose second column is blank is
# non-executable (comments, blank lines, braces). A line is "covered" if its
# count is anything other than literal `0`.
NEW_MANIFEST=$(mktemp)
awk -v root="$ABS_ROOT/" '
    BEGIN { current = ""; print "{" }
    /^\/.*\.rs:$/ {
        if (current != "" && total > 0) {
            pct = (covered * 100.0) / total
            printf "%s  \"%s\": %s", (first ? "" : ",\n"), current, pct
            first = 0
        }
        current = $0
        sub(/:$/, "", current)
        sub(root, "", current)
        if (first == "") first = 1
        total = 0; covered = 0
        next
    }
    current != "" && /^[[:space:]]*[0-9]+\|[[:space:]]+[^|]+\|/ {
        # Extract the second column (between first and second |)
        line = $0
        n = split(line, parts, "|")
        if (n >= 3) {
            count = parts[2]
            gsub(/[[:space:]]/, "", count)
            if (count != "") {
                total++
                if (count != "0") covered++
            }
        }
    }
    END {
        if (current != "" && total > 0) {
            pct = (covered * 100.0) / total
            printf "%s  \"%s\": %s", (first ? "" : ",\n"), current, pct
        }
        print "\n}"
    }
' "$REPORT_FILE" > "$NEW_MANIFEST"

# Validate it's well-formed JSON.
if ! jq empty "$NEW_MANIFEST" 2>/dev/null; then
    echo "error: generated manifest is not valid JSON; awk parser likely broken" >&2
    cat "$NEW_MANIFEST" >&2
    exit 2
fi

NEW_CRAP_MANIFEST=$(mktemp)
cp "$CRAP_REPORT_FILE" "$NEW_CRAP_MANIFEST"

if ! jq empty "$NEW_CRAP_MANIFEST" 2>/dev/null; then
    echo "error: generated CRAP manifest is not valid JSON" >&2
    cat "$NEW_CRAP_MANIFEST" >&2
    exit 2
fi

if [[ "$UPDATE" == "true" ]]; then
    mv "$NEW_MANIFEST" "$MANIFEST_FILE"
    mv "$NEW_CRAP_MANIFEST" "$CRAP_MANIFEST_FILE"
    echo "Coverage and CRAP manifests updated."
    exit 0
fi

INITIALIZED=false
if [[ ! -f "$MANIFEST_FILE" ]]; then
    echo "No coverage manifest found. Creating initial manifest."
    mv "$NEW_MANIFEST" "$MANIFEST_FILE"
    INITIALIZED=true
fi
if [[ ! -f "$CRAP_MANIFEST_FILE" ]]; then
    echo "No CRAP manifest found. Creating initial manifest."
    mv "$NEW_CRAP_MANIFEST" "$CRAP_MANIFEST_FILE"
    INITIALIZED=true
fi
if [[ "$INITIALIZED" == "true" ]]; then
    exit 0
fi

# Compare
echo "Comparing coverage against baseline..."
# We use a 0.05% epsilon to ignore floating point noise
REGRESSIONS=$(jq -n \
    --slurpfile new "$NEW_MANIFEST" \
    --slurpfile old "$MANIFEST_FILE" \
    '$new[0] | to_entries | map(
        .key as $k |
        .value as $v |
        ($old[0][$k] // 100.0) as $o |
        select($v < $o - 0.05) |
        {key: $k, new: $v, old: $o}
    )')

if [[ "$(echo "$REGRESSIONS" | jq 'length')" -gt 0 ]]; then
    echo "error: coverage regressions detected:" >&2
    echo "$REGRESSIONS" | jq -r '.[] | "\(.key): \(.old)% -> \(.new)% (DROP)"' >&2

    if [[ "$INVESTIGATE" == "true" ]]; then
        echo "" >&2
        echo "--- Missing Lines for Regressed Files ---" >&2

        # Build a list of absolute paths for regressed files
        REGRESSED_ABS_PATHS=$(echo "$REGRESSIONS" | jq -r --arg root "$ROOT/" '.[] | ($root + .key)')

        # Filter the cached report to only show the regressing files,
        # printing each file's text block (which includes per-line counts).
        awk -v paths="$REGRESSED_ABS_PATHS" '
            BEGIN {
                split(paths, path_arr, "\n");
                for (i in path_arr) {
                    target_paths[path_arr[i]] = 1;
                }
            }
            /^\/.*\.rs:$/ {
                file = $0;
                sub(/:$/, "", file);
                printing = (file in target_paths) ? 1 : 0;
            }
            printing { print $0 }
        ' "$REPORT_FILE" >&2
    else
        echo "" >&2
        echo "To investigate the missing lines, run: scripts/check-coverage --investigate" >&2
    fi
    exit 1
fi

echo "Comparing CRAP scores against baseline..."
# We use a 0.01 CRAP-score epsilon to ignore floating point noise.
CRAP_REGRESSIONS=$(jq -n \
    --slurpfile new "$NEW_CRAP_MANIFEST" \
    --slurpfile old "$CRAP_MANIFEST_FILE" \
    '
    # Include the line: a file can hold several same-named functions (e.g. the
    # many `from`/`new`/`default`/`fmt` trait impls), so crate|file|function
    # alone collides and the `add` below would keep only the last, making the
    # comparison flag the others as phantom regressions. The line disambiguates.
    def key: ((.crate // "") + "|" + .file + "|" + .function + "|" + ((.line // 0) | tostring));
    (($old[0].entries // []) | map({(key): .}) | add // {}) as $old_by_key |
    ($new[0].entries // []) | map(
        . as $entry |
        key as $k |
        ($old_by_key[$k] // null) as $old_entry |
        select($old_entry != null) |
        select((.crap // 0) > (($old_entry.crap // 0) + 0.01)) |
        {
            crate: (.crate // ""),
            file: .file,
            function: .function,
            old: $old_entry.crap,
            new: .crap,
            delta: (.crap - $old_entry.crap),
            coverage: .coverage,
            cyclomatic: .cyclomatic
        }
    )')

if [[ "$(echo "$CRAP_REGRESSIONS" | jq 'length')" -gt 0 ]]; then
    echo "error: CRAP score regressions detected:" >&2
    echo "$CRAP_REGRESSIONS" | jq -r '
        sort_by(.delta) | reverse | .[] |
        "\(.file): \(.function): \(.old) -> \(.new) (Δ \(.delta), CC \(.cyclomatic), coverage \(.coverage // "n/a")%)"
    ' >&2
    exit 1
fi

# Compare-only mode (the everyday verify gate): the baseline is regenerated
# deliberately from the Nix sandbox (the CI-reproducible environment), so a local
# host run must gate regressions WITHOUT rewriting the committed baseline — host
# numbers differ slightly from the sandbox for network-sensitive files.
if [[ "$CHECK" == "true" ]]; then
    echo "Coverage and CRAP OK (compare-only; baseline not updated)."
    exit 0
fi

# If all good, update
mv "$NEW_MANIFEST" "$MANIFEST_FILE"
mv "$NEW_CRAP_MANIFEST" "$CRAP_MANIFEST_FILE"
echo "Coverage and CRAP OK (coverage at/above baseline, CRAP scores at/below baseline)."
