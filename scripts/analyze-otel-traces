#!/usr/bin/env node

"use strict";

const fs = require("fs");
const path = require("path");

function usage() {
    console.log(`Analyze OpenTelemetry JSONL traces exported by the VM e2e collector.

Usage:
  scripts/analyze-otel-traces [--top N] [--trace TRACE_ID] <otel-traces.jsonl>...

Examples:
  scripts/analyze-otel-traces /nix/store/.../otel-traces.jsonl
  scripts/analyze-otel-traces --top 40 --trace 11111111111111111111111111111111 /nix/store/.../otel-traces.jsonl`);
}

function parseArgs(argv) {
    let top = 25;
    let traceFilter = "";
    const inputs = [];

    for (let i = 0; i < argv.length; i += 1) {
        const arg = argv[i];
        if (arg === "--top") {
            i += 1;
            if (i >= argv.length) {
                throw new Error("--top requires a value");
            }
            const parsed = Number.parseInt(argv[i], 10);
            if (!Number.isInteger(parsed) || parsed <= 0) {
                throw new Error("--top must be a positive integer");
            }
            top = parsed;
            continue;
        }
        if (arg === "--trace") {
            i += 1;
            if (i >= argv.length) {
                throw new Error("--trace requires a value");
            }
            traceFilter = argv[i];
            continue;
        }
        if (arg === "--help" || arg === "-h") {
            usage();
            process.exit(0);
        }
        inputs.push(arg);
    }

    if (inputs.length === 0) {
        throw new Error("at least one input file is required");
    }

    return { top, traceFilter, inputs };
}

function getAttr(span, key) {
    const attrs = Array.isArray(span.attributes) ? span.attributes : [];
    const attr = attrs.find((entry) => entry && entry.key === key);
    if (!attr || !attr.value) {
        return "";
    }
    if (typeof attr.value.stringValue === "string") {
        return attr.value.stringValue;
    }
    if (attr.value.intValue !== undefined && attr.value.intValue !== null) {
        return String(attr.value.intValue);
    }
    return "";
}

function parseJsonAttr(span, key, fallback) {
    const raw = getAttr(span, key);
    if (!raw) {
        return fallback;
    }
    try {
        return JSON.parse(raw);
    } catch (_error) {
        return fallback;
    }
}

function parseDurationMs(span) {
    const start = BigInt(span.startTimeUnixNano);
    const end = BigInt(span.endTimeUnixNano);
    const nanos = end - start;
    return Number(nanos) / 1_000_000;
}

function readSpans(filePath, traceFilter) {
    const raw = fs.readFileSync(filePath, "utf8");
    const lines = raw.split("\n").filter((line) => line.trim().length > 0);
    const spans = [];

    for (const line of lines) {
        let record;
        try {
            record = JSON.parse(line);
        } catch (error) {
            throw new Error(
                `failed to parse JSON line in ${filePath}: ${error.message}`,
            );
        }

        const resourceSpans = Array.isArray(record.resourceSpans)
            ? record.resourceSpans
            : [];
        for (const resourceSpan of resourceSpans) {
            const scopeSpans = Array.isArray(resourceSpan.scopeSpans)
                ? resourceSpan.scopeSpans
                : [];
            for (const scopeSpan of scopeSpans) {
                const nestedSpans = Array.isArray(scopeSpan.spans)
                    ? scopeSpan.spans
                    : [];
                for (const span of nestedSpans) {
                    if (traceFilter && span.traceId !== traceFilter) {
                        continue;
                    }
                    spans.push({
                        raw: span,
                        source: filePath,
                        traceId: span.traceId || "",
                        spanId: span.spanId || "",
                        parentSpanId: span.parentSpanId || "",
                        name: span.name || "",
                        method: getAttr(span, "method"),
                        uri: getAttr(span, "uri"),
                        busyNs: getAttr(span, "busy_ns"),
                        idleNs: getAttr(span, "idle_ns"),
                        durationMs: parseDurationMs(span),
                    });
                }
            }
        }
    }

    return spans;
}

function padRight(value, width) {
    const stringValue = String(value);
    if (stringValue.length >= width) {
        return stringValue;
    }
    return stringValue + " ".repeat(width - stringValue.length);
}

function padLeft(value, width) {
    const stringValue = String(value);
    if (stringValue.length >= width) {
        return stringValue;
    }
    return " ".repeat(width - stringValue.length) + stringValue;
}

function truncate(value, width) {
    const stringValue = String(value);
    if (stringValue.length <= width) {
        return stringValue;
    }
    return stringValue.slice(0, width - 1) + "…";
}

function printSlowest(spans, top) {
    const sorted = [...spans]
        .sort((a, b) => b.durationMs - a.durationMs)
        .slice(0, top);

    console.log(`Top ${top} slowest spans`);
    console.log(
        "duration_ms  trace_id                           span                                method  uri                       busy_ns     idle_ns     source",
    );

    for (const span of sorted) {
        const row = [
            padLeft(span.durationMs.toFixed(3), 10),
            padRight(truncate(span.traceId, 32), 32),
            padRight(truncate(span.name || "-", 34), 34),
            padRight(truncate(span.method || "-", 6), 6),
            padRight(truncate(span.uri || "-", 25), 25),
            padLeft(span.busyNs || "-", 10),
            padLeft(span.idleNs || "-", 10),
            span.source,
        ];
        console.log(row.join("  "));
    }

    console.log("");
}

function printSlowestE2eTests(spans, top) {
    const e2eTests = spans
        .filter((span) => span.name === "e2e.test")
        .map((span) => ({
            durationMs: span.durationMs,
            traceId: span.traceId,
            project: getAttr(span.raw, "e2e.project") || "-",
            test: getAttr(span.raw, "e2e.test") || "-",
            actionCount: getAttr(span.raw, "e2e.action_count") || "0",
            requestCount: getAttr(span.raw, "e2e.request_count") || "0",
        }))
        .sort((a, b) => b.durationMs - a.durationMs)
        .slice(0, top);

    if (e2eTests.length === 0) {
        return;
    }

    console.log(`Top ${top} slowest e2e.test spans`);
    console.log(
        "duration_ms  project    actions  requests  trace_id                           test",
    );
    for (const row of e2eTests) {
        const values = [
            padLeft(row.durationMs.toFixed(3), 10),
            padRight(truncate(row.project, 9), 9),
            padLeft(row.actionCount, 7),
            padLeft(row.requestCount, 8),
            padRight(truncate(row.traceId, 32), 32),
            truncate(row.test, 50),
        ];
        console.log(values.join("  "));
    }
    console.log("");
}

function printE2eActionHotspots(spans, top) {
    const totals = new Map();
    const e2eTests = spans.filter((span) => span.name === "e2e.test");

    for (const span of e2eTests) {
        const topActions = parseJsonAttr(span.raw, "e2e.action_top_json", []);
        if (!Array.isArray(topActions)) {
            continue;
        }

        for (const action of topActions) {
            const name = typeof action.name === "string" ? action.name : "";
            const durationMs = Number(action.durationMs);
            if (!name || !Number.isFinite(durationMs)) {
                continue;
            }

            const existing = totals.get(name) || {
                count: 0,
                totalMs: 0,
                maxMs: 0,
            };
            existing.count += 1;
            existing.totalMs += durationMs;
            existing.maxMs = Math.max(existing.maxMs, durationMs);
            totals.set(name, existing);
        }
    }

    const rows = [...totals.entries()]
        .map(([name, stats]) => ({
            name,
            count: stats.count,
            avgMs: stats.totalMs / stats.count,
            maxMs: stats.maxMs,
            totalMs: stats.totalMs,
        }))
        .sort((a, b) => b.maxMs - a.maxMs)
        .slice(0, top);

    if (rows.length === 0) {
        return;
    }

    console.log(`Top ${top} e2e action hotspots (from e2e.action_top_json)`);
    console.log("max_ms      avg_ms      total_ms     count  action");
    for (const row of rows) {
        console.log(
            `${padLeft(row.maxMs.toFixed(3), 10)}  ${padLeft(row.avgMs.toFixed(3), 10)}  ${padLeft(row.totalMs.toFixed(3), 10)}  ${padLeft(row.count, 5)}  ${row.name}`,
        );
    }
    console.log("");
}

function toUrlPath(value) {
    if (typeof value !== "string" || value.length === 0) {
        return "";
    }
    try {
        const parsed = new URL(value);
        return `${parsed.host}${parsed.pathname}`;
    } catch (_error) {
        return value;
    }
}

function asFiniteNumber(value) {
    return typeof value === "number" && Number.isFinite(value) ? value : null;
}

function printE2eNavigationHotspots(spans, top) {
    const phaseTotals = new Map();
    const urlTotals = new Map();
    const e2eTests = spans.filter((span) => span.name === "e2e.test");

    const addPhase = (name, value) => {
        if (!Number.isFinite(value) || value < 0) {
            return;
        }
        const current = phaseTotals.get(name) || {
            count: 0,
            totalMs: 0,
            maxMs: 0,
        };
        current.count += 1;
        current.totalMs += value;
        current.maxMs = Math.max(current.maxMs, value);
        phaseTotals.set(name, current);
    };

    for (const span of e2eTests) {
        const topNavigations = parseJsonAttr(
            span.raw,
            "e2e.navigation_top_json",
            [],
        );
        if (!Array.isArray(topNavigations)) {
            continue;
        }

        for (const navigation of topNavigations) {
            const totalMs = asFiniteNumber(navigation.totalMs);
            const requestMs = asFiniteNumber(navigation.requestMs);
            const commitToDomContentLoadedMs = asFiniteNumber(
                navigation.commitToDomContentLoadedMs,
            );
            const commitToHydrationMs = asFiniteNumber(
                navigation.commitToHydrationMs,
            );
            const domContentLoadedToLoadMs = asFiniteNumber(
                navigation.domContentLoadedToLoadMs,
            );
            const loadToHydrationMs = asFiniteNumber(
                navigation.loadToHydrationMs,
            );
            const wasmInitMs = asFiniteNumber(navigation.wasmInitMs);
            const leptosHydrateMs = asFiniteNumber(navigation.leptosHydrateMs);
            const postHydrateEffectsMs = asFiniteNumber(
                navigation.postHydrateEffectsMs,
            );

            addPhase("navigation.total", totalMs);
            addPhase("navigation.request", requestMs);
            addPhase(
                "navigation.commit_to_domcontentloaded",
                commitToDomContentLoadedMs,
            );
            addPhase("navigation.commit_to_hydration", commitToHydrationMs);
            addPhase(
                "navigation.domcontentloaded_to_load",
                domContentLoadedToLoadMs,
            );
            addPhase("navigation.load_to_hydration", loadToHydrationMs);
            addPhase("navigation.wasm_init", wasmInitMs);
            addPhase("navigation.leptos_hydrate", leptosHydrateMs);
            addPhase("navigation.post_hydrate_effects", postHydrateEffectsMs);

            const urlPath = toUrlPath(navigation.url);
            if (!urlPath || totalMs === null || totalMs < 0) {
                continue;
            }
            const currentUrl = urlTotals.get(urlPath) || {
                count: 0,
                totalMs: 0,
                maxMs: 0,
            };
            currentUrl.count += 1;
            currentUrl.totalMs += totalMs;
            currentUrl.maxMs = Math.max(currentUrl.maxMs, totalMs);
            urlTotals.set(urlPath, currentUrl);
        }
    }

    const phaseRows = [...phaseTotals.entries()]
        .map(([name, stats]) => ({
            name,
            count: stats.count,
            avgMs: stats.totalMs / stats.count,
            maxMs: stats.maxMs,
            totalMs: stats.totalMs,
        }))
        .sort((a, b) => b.maxMs - a.maxMs)
        .slice(0, top);
    if (phaseRows.length > 0) {
        console.log(
            `Top ${top} navigation phase hotspots (from e2e.navigation_top_json)`,
        );
        console.log("max_ms      avg_ms      total_ms     count  phase");
        for (const row of phaseRows) {
            console.log(
                `${padLeft(row.maxMs.toFixed(3), 10)}  ${padLeft(row.avgMs.toFixed(3), 10)}  ${padLeft(row.totalMs.toFixed(3), 10)}  ${padLeft(row.count, 5)}  ${row.name}`,
            );
        }
        console.log("");
    }

    const urlRows = [...urlTotals.entries()]
        .map(([path, stats]) => ({
            path,
            count: stats.count,
            avgMs: stats.totalMs / stats.count,
            maxMs: stats.maxMs,
            totalMs: stats.totalMs,
        }))
        .sort((a, b) => b.maxMs - a.maxMs)
        .slice(0, top);
    if (urlRows.length > 0) {
        console.log(`Top ${top} slow navigation targets`);
        console.log("max_ms      avg_ms      total_ms     count  target");
        for (const row of urlRows) {
            console.log(
                `${padLeft(row.maxMs.toFixed(3), 10)}  ${padLeft(row.avgMs.toFixed(3), 10)}  ${padLeft(row.totalMs.toFixed(3), 10)}  ${padLeft(row.count, 5)}  ${row.path}`,
            );
        }
        console.log("");
    }
}

function printE2eLongTaskHotspots(spans, top) {
    const totals = new Map();
    const byProject = new Map();
    const e2eTests = spans.filter((span) => span.name === "e2e.test");

    for (const span of e2eTests) {
        const project = getAttr(span.raw, "e2e.project") || "-";
        const tasks = parseJsonAttr(span.raw, "e2e.long_tasks_json", []);
        if (!Array.isArray(tasks)) {
            continue;
        }
        const currentProject = byProject.get(project) || {
            tests: 0,
            taskCount: 0,
            totalMs: 0,
            maxMs: 0,
        };
        currentProject.tests += 1;
        byProject.set(project, currentProject);

        for (const task of tasks) {
            const durationMs = Number(task.duration);
            if (!Number.isFinite(durationMs) || durationMs < 0) {
                continue;
            }
            const name =
                typeof task.name === "string" && task.name.length > 0
                    ? task.name
                    : "longtask";
            const current = totals.get(name) || {
                count: 0,
                totalMs: 0,
                maxMs: 0,
            };
            current.count += 1;
            current.totalMs += durationMs;
            current.maxMs = Math.max(current.maxMs, durationMs);
            totals.set(name, current);

            currentProject.taskCount += 1;
            currentProject.totalMs += durationMs;
            currentProject.maxMs = Math.max(currentProject.maxMs, durationMs);
        }
    }

    const rows = [...totals.entries()]
        .map(([name, stats]) => ({
            name,
            count: stats.count,
            avgMs: stats.totalMs / stats.count,
            maxMs: stats.maxMs,
            totalMs: stats.totalMs,
        }))
        .sort((a, b) => b.maxMs - a.maxMs)
        .slice(0, top);

    if (rows.length > 0) {
        console.log(`Top ${top} long-task hotspots (from e2e.long_tasks_json)`);
        console.log("max_ms      avg_ms      total_ms     count  task_name");
        for (const row of rows) {
            console.log(
                `${padLeft(row.maxMs.toFixed(3), 10)}  ${padLeft(row.avgMs.toFixed(3), 10)}  ${padLeft(row.totalMs.toFixed(3), 10)}  ${padLeft(row.count, 5)}  ${row.name}`,
            );
        }
        console.log("");
    }

    const projectRows = [...byProject.entries()]
        .map(([project, stats]) => ({
            project,
            tests: stats.tests,
            taskCount: stats.taskCount,
            avgPerTestMs: stats.tests > 0 ? stats.totalMs / stats.tests : 0,
            maxMs: stats.maxMs,
        }))
        .sort((a, b) => b.avgPerTestMs - a.avgPerTestMs);

    if (projectRows.length > 0) {
        console.log("Long-task totals by project");
        console.log(
            "project     tests     tasks     avg_ms_per_test  max_task_ms",
        );
        for (const row of projectRows) {
            console.log(
                `${padRight(truncate(row.project, 9), 9)}  ${padLeft(row.tests, 5)}  ${padLeft(row.taskCount, 7)}  ${padLeft(row.avgPerTestMs.toFixed(3), 15)}  ${padLeft(row.maxMs.toFixed(3), 11)}`,
            );
        }
        console.log("");
    }
}

function printE2eResourceHotspots(spans, top) {
    const initiatorTotals = new Map();
    const assetTotals = new Map();
    const e2eTests = spans.filter((span) => span.name === "e2e.test");

    for (const span of e2eTests) {
        const summary = parseJsonAttr(
            span.raw,
            "e2e.resource_summary_json",
            {},
        );
        if (!summary || typeof summary !== "object") {
            continue;
        }
        const topSlow = Array.isArray(summary.topSlow) ? summary.topSlow : [];
        for (const item of topSlow) {
            const durationMs = Number(item.durationMs);
            if (!Number.isFinite(durationMs) || durationMs < 0) {
                continue;
            }
            const initiator =
                typeof item.initiatorType === "string" &&
                item.initiatorType.length > 0
                    ? item.initiatorType
                    : "unknown";
            const name =
                typeof item.name === "string" && item.name.length > 0
                    ? toUrlPath(item.name)
                    : "unknown";

            const byInitiator = initiatorTotals.get(initiator) || {
                count: 0,
                totalMs: 0,
                maxMs: 0,
            };
            byInitiator.count += 1;
            byInitiator.totalMs += durationMs;
            byInitiator.maxMs = Math.max(byInitiator.maxMs, durationMs);
            initiatorTotals.set(initiator, byInitiator);

            const byAsset = assetTotals.get(name) || {
                count: 0,
                totalMs: 0,
                maxMs: 0,
                initiator,
            };
            byAsset.count += 1;
            byAsset.totalMs += durationMs;
            byAsset.maxMs = Math.max(byAsset.maxMs, durationMs);
            assetTotals.set(name, byAsset);
        }
    }

    const initiatorRows = [...initiatorTotals.entries()]
        .map(([initiator, stats]) => ({
            initiator,
            count: stats.count,
            avgMs: stats.totalMs / stats.count,
            maxMs: stats.maxMs,
            totalMs: stats.totalMs,
        }))
        .sort((a, b) => b.maxMs - a.maxMs)
        .slice(0, top);
    if (initiatorRows.length > 0) {
        console.log(
            `Top ${top} resource initiator hotspots (from e2e.resource_summary_json)`,
        );
        console.log("max_ms      avg_ms      total_ms     count  initiator");
        for (const row of initiatorRows) {
            console.log(
                `${padLeft(row.maxMs.toFixed(3), 10)}  ${padLeft(row.avgMs.toFixed(3), 10)}  ${padLeft(row.totalMs.toFixed(3), 10)}  ${padLeft(row.count, 5)}  ${row.initiator}`,
            );
        }
        console.log("");
    }

    const assetRows = [...assetTotals.entries()]
        .map(([name, stats]) => ({
            name,
            initiator: stats.initiator,
            count: stats.count,
            avgMs: stats.totalMs / stats.count,
            maxMs: stats.maxMs,
            totalMs: stats.totalMs,
        }))
        .sort((a, b) => b.maxMs - a.maxMs)
        .slice(0, top);
    if (assetRows.length > 0) {
        console.log(`Top ${top} slow resource assets`);
        console.log(
            "max_ms      avg_ms      total_ms     count  initiator  asset",
        );
        for (const row of assetRows) {
            console.log(
                `${padLeft(row.maxMs.toFixed(3), 10)}  ${padLeft(row.avgMs.toFixed(3), 10)}  ${padLeft(row.totalMs.toFixed(3), 10)}  ${padLeft(row.count, 5)}  ${padRight(truncate(row.initiator, 9), 9)}  ${truncate(row.name, 80)}`,
            );
        }
        console.log("");
    }
}

function printE2eHydrationVsApi(spans, top) {
    const rows = spans
        .filter((span) => span.name === "e2e.test")
        .map((span) => {
            const project = getAttr(span.raw, "e2e.project") || "-";
            const testName = getAttr(span.raw, "e2e.test") || "-";
            const traceId = span.traceId || "-";
            const navigations = parseJsonAttr(
                span.raw,
                "e2e.navigation_top_json",
                [],
            );
            const requests = parseJsonAttr(
                span.raw,
                "e2e.request_top_slow_json",
                [],
            );
            let hydrationMs = 0;
            if (Array.isArray(navigations)) {
                for (const navigation of navigations) {
                    const value = Number(navigation.commitToHydrationMs);
                    if (Number.isFinite(value) && value > 0) {
                        hydrationMs += value;
                    }
                }
            }
            let apiMs = 0;
            if (Array.isArray(requests)) {
                for (const request of requests) {
                    const url =
                        typeof request.url === "string" ? request.url : "";
                    if (!url.includes("/api/")) {
                        continue;
                    }
                    const value = Number(request.durationMs);
                    if (Number.isFinite(value) && value > 0) {
                        apiMs += value;
                    }
                }
            }
            const ratio = apiMs > 0 ? hydrationMs / apiMs : null;
            return {
                project,
                testName,
                traceId,
                hydrationMs,
                apiMs,
                ratio,
            };
        })
        .sort((a, b) => b.hydrationMs - a.hydrationMs)
        .slice(0, top);

    if (rows.length === 0) {
        return;
    }

    console.log(
        `Top ${top} tests by navigation hydration budget vs API budget`,
    );
    console.log(
        "hydration_ms  api_ms      hyd/api   project    trace_id                           test",
    );
    for (const row of rows) {
        console.log(
            `${padLeft(row.hydrationMs.toFixed(3), 12)}  ${padLeft(row.apiMs.toFixed(3), 10)}  ${padLeft(row.ratio === null ? "-" : row.ratio.toFixed(2), 7)}  ${padRight(truncate(row.project, 9), 9)}  ${padRight(truncate(row.traceId, 32), 32)}  ${truncate(row.testName, 42)}`,
        );
    }
    console.log("");
}

function printE2eByProject(spans) {
    const tests = spans.filter((span) => span.name === "e2e.test");
    if (tests.length === 0) {
        return;
    }

    const totals = new Map();
    for (const span of tests) {
        const project = getAttr(span.raw, "e2e.project") || "-";
        const actionCount = Number(
            getAttr(span.raw, "e2e.action_count") || "0",
        );
        const requestCount = Number(
            getAttr(span.raw, "e2e.request_count") || "0",
        );
        const current = totals.get(project) || {
            count: 0,
            totalMs: 0,
            maxMs: 0,
            actions: 0,
            requests: 0,
        };
        current.count += 1;
        current.totalMs += span.durationMs;
        current.maxMs = Math.max(current.maxMs, span.durationMs);
        current.actions += Number.isFinite(actionCount) ? actionCount : 0;
        current.requests += Number.isFinite(requestCount) ? requestCount : 0;
        totals.set(project, current);
    }

    const rows = [...totals.entries()]
        .map(([project, stats]) => ({
            project,
            count: stats.count,
            avgMs: stats.totalMs / stats.count,
            maxMs: stats.maxMs,
            avgActions: stats.actions / stats.count,
            avgRequests: stats.requests / stats.count,
        }))
        .sort((a, b) => b.avgMs - a.avgMs);

    console.log("E2E test duration by project");
    console.log(
        "project     tests     avg_ms      max_ms      avg_actions  avg_requests",
    );
    for (const row of rows) {
        console.log(
            `${padRight(truncate(row.project, 9), 9)}  ${padLeft(row.count, 5)}  ${padLeft(row.avgMs.toFixed(3), 10)}  ${padLeft(row.maxMs.toFixed(3), 10)}  ${padLeft(row.avgActions.toFixed(2), 11)}  ${padLeft(row.avgRequests.toFixed(2), 12)}`,
        );
    }
    console.log("");
}

function printTraceTotals(spans, top) {
    const totals = new Map();

    for (const span of spans) {
        const current = totals.get(span.traceId) || { totalMs: 0, spans: 0 };
        current.totalMs += span.durationMs;
        current.spans += 1;
        totals.set(span.traceId, current);
    }

    const rows = [...totals.entries()]
        .map(([traceId, info]) => ({
            traceId,
            totalMs: info.totalMs,
            spans: info.spans,
        }))
        .sort((a, b) => b.totalMs - a.totalMs)
        .slice(0, top);

    console.log("Trace totals (sum of span durations)");
    console.log("total_ms     spans  trace_id");
    for (const row of rows) {
        console.log(
            `${padLeft(row.totalMs.toFixed(3), 10)}  ${padLeft(row.spans, 5)}  ${row.traceId}`,
        );
    }
}

function main() {
    let parsed;
    try {
        parsed = parseArgs(process.argv.slice(2));
    } catch (error) {
        console.error(`error: ${error.message}`);
        usage();
        process.exit(1);
    }

    const allSpans = [];

    for (const input of parsed.inputs) {
        const resolved = path.resolve(input);
        if (!fs.existsSync(resolved) || !fs.statSync(resolved).isFile()) {
            console.error(`error: file not found: ${input}`);
            process.exit(1);
        }

        try {
            const spans = readSpans(resolved, parsed.traceFilter);
            allSpans.push(...spans);
        } catch (error) {
            console.error(`error: ${error.message}`);
            process.exit(1);
        }
    }

    if (allSpans.length === 0) {
        console.log("No spans found in the provided trace files.");
        return;
    }

    printSlowest(allSpans, parsed.top);
    printSlowestE2eTests(allSpans, parsed.top);
    printE2eActionHotspots(allSpans, parsed.top);
    printE2eNavigationHotspots(allSpans, parsed.top);
    printE2eLongTaskHotspots(allSpans, parsed.top);
    printE2eResourceHotspots(allSpans, parsed.top);
    printE2eHydrationVsApi(allSpans, parsed.top);
    printE2eByProject(allSpans);
    printTraceTotals(allSpans, parsed.top);
}

main();
