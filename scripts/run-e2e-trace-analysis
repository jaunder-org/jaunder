#!/usr/bin/env node

"use strict";

const fs = require("fs");
const path = require("path");
const { spawnSync } = require("child_process");

function usage() {
    console.log(`Run e2e VM checks and analyze OTEL traces.

Usage:
  scripts/run-e2e-trace-analysis [--top N] [--trace TRACE_ID] [--cold] [--browser chromium|firefox]

Examples:
  scripts/run-e2e-trace-analysis
  scripts/run-e2e-trace-analysis --top 40
  scripts/run-e2e-trace-analysis --trace 11111111111111111111111111111111
  scripts/run-e2e-trace-analysis --cold
  scripts/run-e2e-trace-analysis --browser firefox`);
}

function parseArgs(argv) {
    let top = 25;
    let traceId = "";
    let cold = false;
    let browser = null;

    for (let i = 0; i < argv.length; i += 1) {
        const arg = argv[i];
        if (arg === "--top") {
            i += 1;
            if (i >= argv.length) {
                throw new Error("--top requires a value");
            }
            const parsed = Number.parseInt(argv[i], 10);
            if (!Number.isInteger(parsed) || parsed <= 0) {
                throw new Error("--top must be a positive integer");
            }
            top = parsed;
            continue;
        }
        if (arg === "--trace") {
            i += 1;
            if (i >= argv.length) {
                throw new Error("--trace requires a value");
            }
            traceId = argv[i];
            continue;
        }
        if (arg === "--cold") {
            cold = true;
            continue;
        }
        if (arg === "--browser") {
            i += 1;
            if (i >= argv.length) {
                throw new Error("--browser requires a value");
            }
            if (argv[i] !== "chromium" && argv[i] !== "firefox") {
                throw new Error("--browser must be chromium or firefox");
            }
            browser = argv[i];
            continue;
        }
        if (arg === "--help" || arg === "-h") {
            usage();
            process.exit(0);
        }
        throw new Error(`unknown argument: ${arg}`);
    }

    return { top, traceId, cold, browser };
}

function runAndCapture(command, args) {
    const result = spawnSync(command, args, { encoding: "utf8" });
    if (result.status !== 0) {
        if (result.stdout) {
            process.stdout.write(result.stdout);
        }
        if (result.stderr) {
            process.stderr.write(result.stderr);
        }
        throw new Error(
            `${command} ${args.join(" ")} failed with exit code ${result.status}`,
        );
    }

    const output = [result.stdout, result.stderr]
        .filter((value) => typeof value === "string" && value.length > 0)
        .join("\n");

    return output;
}

function buildCheck(attrPath) {
    const checkName = attrPath.split(".").at(-1);
    console.log(`\n==> Running ${checkName}`);
    const output = runAndCapture("nix", [
        "build",
        `.#${attrPath}`,
        "--no-link",
        "--print-out-paths",
    ]);

    const storePath = output
        .split("\n")
        .map((line) => line.trim())
        .filter(
            (line) => line.startsWith("/nix/store/") && !line.endsWith(".drv"),
        )
        .at(-1);

    if (!storePath) {
        throw new Error(`could not parse output path for ${checkName}`);
    }

    console.log(`    output: ${storePath}`);
    return storePath;
}

function main() {
    let parsed;
    try {
        parsed = parseArgs(process.argv.slice(2));
    } catch (error) {
        console.error(`error: ${error.message}`);
        usage();
        process.exit(1);
    }

    const browsers = parsed.browser ? [parsed.browser] : ["chromium", "firefox"];
    const ns = parsed.cold ? "packages" : "checks";
    const suffix = parsed.cold ? "-cold" : "";

    const traceFiles = [];
    for (const backend of ["sqlite", "postgres"]) {
        for (const browser of browsers) {
            const attr = `${ns}.x86_64-linux.e2e-${backend}-${browser}${suffix}`;
            const out = buildCheck(attr);
            const traceFile = path.join(
                out,
                `otel-traces-${backend}.jsonl`,
                "otel-traces.jsonl",
            );
            if (!fs.existsSync(traceFile)) {
                throw new Error(`trace file not found: ${traceFile}`);
            }
            traceFiles.push(traceFile);
        }
    }

    console.log("\n==> Running trace analyzer");
    const analyzer = path.join(process.cwd(), "scripts", "analyze-otel-traces");
    const analyzerArgs = ["--top", String(parsed.top)];
    if (parsed.traceId) {
        analyzerArgs.push("--trace", parsed.traceId);
    }
    analyzerArgs.push(...traceFiles);

    const result = spawnSync(analyzer, analyzerArgs, {
        stdio: "inherit",
        encoding: "utf8",
    });
    if (result.status !== 0) {
        process.exit(result.status ?? 1);
    }
}

main();
