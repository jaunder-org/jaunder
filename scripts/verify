#!/usr/bin/env bash
# Run the standard project verification sequence.
#
# Usage:
#   scripts/verify --fast   # inner loop: static checks + clippy only (no tests, no VM)
#   scripts/verify          # commit gate: static + clippy + tests (SQLite + host
#                           #   PostgreSQL) + host e2e. No coverage, no VM.
#   scripts/verify --full   # commit gate plus coverage and the hermetic Nix VM
#                           #   checks (e2e + PostgreSQL integration). Enforced by CI.
#
# --fast runs the static checks (fmt, leptosfmt, prettier, cargo-deny) and clippy,
# then stops. The default (commit) gate adds the breakage-catching tests: nextest
# against SQLite, the same integration suite against a throwaway host PostgreSQL
# (backend parity), and the end-to-end suite on the host — all without a VM. It is
# deliberately about catching breakage, not coverage. --full additionally runs
# coverage and the Nix VM checks; both are also enforced by CI, so that tier is
# opt-in locally.
#
# Optional env:
#   VERIFY_PASSTHROUGH=1         Stream each step output directly (sequential).
#   VERIFY_SHOW_STEP_OUTPUT=1    Print captured output for successful steps.
#   VERIFY_SHOW_FAILURE_LOG=1    Print captured output when a step fails (default: 1).
#   VERIFY_FAILURE_LOG_LINES=200 Number of failure log lines to print.
set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

FAST=0
FULL=0
for arg in "$@"; do
    case "$arg" in
        --fast) FAST=1 ;;
        --full) FULL=1 ;;
        *)
            echo "error: unknown argument: $arg" >&2
            echo "usage: scripts/verify [--fast|--full]" >&2
            exit 2
            ;;
    esac
done

FAILURE_LOG_LINES="${VERIFY_FAILURE_LOG_LINES:-200}"

# ── Helpers ───────────────────────────────────────────────────────────

run_step() {
    local label="$1"
    shift

    echo "--- verify: ${label} ---"

    if [[ "${VERIFY_PASSTHROUGH:-0}" == "1" ]]; then
        "$@"
        return 0
    fi

    local step_log
    step_log="$(mktemp)"
    if "$@" >"$step_log" 2>&1; then
        if [[ "${VERIFY_SHOW_STEP_OUTPUT:-0}" == "1" ]]; then
            cat "$step_log"
        fi
        rm -f "$step_log"
        return 0
    fi

    echo "--- verify: FAILED: ${label} ---"
    if [[ "${VERIFY_SHOW_FAILURE_LOG:-1}" == "1" ]]; then
        echo "--- verify: failure output (last ${FAILURE_LOG_LINES} lines) ---"
        tail -n "$FAILURE_LOG_LINES" "$step_log"
    fi
    rm -f "$step_log"
    return 1
}

# Run multiple checks in parallel, collect results, fail if any failed.
# Usage: run_parallel "label1" cmd1 arg1 -- "label2" cmd2 arg2 -- ...
run_parallel() {
    if [[ "${VERIFY_PASSTHROUGH:-0}" == "1" ]]; then
        # In passthrough mode, run sequentially with streaming output.
        while [[ $# -gt 0 ]]; do
            local label="$1"; shift
            local -a cmd=()
            while [[ $# -gt 0 && "$1" != "--" ]]; do
                cmd+=("$1"); shift
            done
            [[ $# -gt 0 ]] && shift  # consume --
            run_step "$label" "${cmd[@]}"
        done
        return 0
    fi

    local -a labels=()
    local -a logs=()
    local -a pids=()
    local failed=0

    while [[ $# -gt 0 ]]; do
        local label="$1"; shift
        local -a cmd=()
        while [[ $# -gt 0 && "$1" != "--" ]]; do
            cmd+=("$1"); shift
        done
        [[ $# -gt 0 ]] && shift  # consume --

        echo "--- verify: ${label} ---"
        local log
        log="$(mktemp)"
        labels+=("$label")
        logs+=("$log")

        # Capture cmd into a string for the subshell (avoid array scoping issues).
        local cmd_str
        cmd_str=$(printf '%q ' "${cmd[@]}")
        ( eval "$cmd_str" >"$log" 2>&1 ) &
        pids+=($!)
    done

    for i in "${!pids[@]}"; do
        if ! wait "${pids[$i]}"; then
            echo "--- verify: FAILED: ${labels[$i]} ---"
            if [[ "${VERIFY_SHOW_FAILURE_LOG:-1}" == "1" ]]; then
                echo "--- verify: failure output (last ${FAILURE_LOG_LINES} lines) ---"
                tail -n "$FAILURE_LOG_LINES" "${logs[$i]}"
            fi
            failed=1
        elif [[ "${VERIFY_SHOW_STEP_OUTPUT:-0}" == "1" ]]; then
            cat "${logs[$i]}"
        fi
        rm -f "${logs[$i]}"
    done

    if [[ $failed -ne 0 ]]; then
        return 1
    fi
}

# ── Phase 1: Fast checks (parallel, no compilation) ──────────────────

run_parallel \
    "cargo fmt --check"                cargo fmt --check \
    -- \
    "leptosfmt --check"                leptosfmt -x .direnv -x .git -x target --check '**/*.rs' \
    -- \
    "prettier --check end2end"         prettier --check end2end \
    -- \
    "cargo deny check"                 cargo deny check

# ── Phase 2: Lint (compiles workspace) ────────────────────────────────

run_step "cargo clippy -- -D warnings" cargo clippy -- -D warnings

if [[ "$FAST" == "1" ]]; then
    echo "--- verify: fast checks passed (skipped tests + e2e + nix VM; run 'scripts/verify' for the commit gate) ---"
    exit 0
fi

if [[ "$FULL" != "1" ]]; then
    # ── Phase 3: Tests (commit gate) — catch breakage, no VM ─────────
    # SQLite unit + integration, then the same integration suite against a
    # throwaway host PostgreSQL (backend parity), then host e2e. These are
    # skipped under --full because coverage and the Nix VM checks below re-run
    # the same suites more thoroughly.
    run_step "cargo nextest run (SQLite)" cargo nextest run

    run_step "cargo nextest run -p jaunder (host PostgreSQL)" \
        scripts/with-ephemeral-postgres cargo nextest run -p jaunder --run-ignored all

    run_step "scripts/e2e-local.sh (host e2e)" scripts/e2e-local.sh

    echo "--- verify: commit gate passed (tests + e2e; skipped coverage + nix VM — run 'scripts/verify --full' or rely on CI) ---"
    exit 0
fi

# ── Phase 3 (--full): comprehensive certification ────────────────────
# coverage re-runs the SQLite + host-PostgreSQL suites under instrumentation,
# and the Nix VM checks run the e2e suite hermetically (both browsers, both
# backends) plus the PostgreSQL integration binaries — so the plain commit-gate
# tests would be redundant here and are skipped. Both also run in CI.

run_step "scripts/check-coverage" scripts/check-coverage

run_step "nix build .#nix-only-checks" \
    nix build --accept-flake-config .#nix-only-checks

echo "--- verify: all checks passed (incl. coverage + Nix VM) ---"
