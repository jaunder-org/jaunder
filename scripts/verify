#!/usr/bin/env bash
# Run the standard project verification sequence.
#
# Usage:
#   scripts/verify
set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

run_step() {
    local label="$1"
    shift

    echo "--- verify: ${label} ---"
    "$@"
}

run_step "cargo fmt --check" cargo fmt --check
run_step "leptosfmt --check" leptosfmt -x .direnv -x .git -x target --check '**/*.rs'
run_step "prettier --check end2end" prettier --check end2end
run_step "cargo clippy -- -D warnings" cargo clippy -- -D warnings
run_step "cargo build" cargo build
run_step "cargo nextest run" cargo nextest run
run_step "scripts/check-coverage" scripts/check-coverage
run_step "nix flake check" nix flake check

echo "--- verify: all checks passed ---"
