#!/usr/bin/env bash
# Regenerate the committed coverage + CRAP baselines from the reproducible,
# no-network Nix sandbox (the CI environment), then copy them into the repo.
#
# This is the ONLY correct way to re-baseline. A local host
# `scripts/check-coverage --update` bakes in higher numbers for
# network-sensitive files (e.g. server/src/websub/http.rs, server/src/commands.rs)
# than the sandboxed CI run can reproduce, which then fails the gate.
#
# The build uses the current working tree (dirty trees are picked up with a
# warning), so uncommitted source changes are reflected in the new baseline.
# Baseline changes require review/approval and must be committed alongside the
# source change that moved coverage. See CONTRIBUTING.md "Coverage and
# dependency policy".
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT"

echo "Building .#coverage-update in the Nix sandbox (this runs the full"
echo "instrumented coverage suite and may take a while)..."
out="$(nix build .#coverage-update --no-link --print-out-paths)"

cp "$out/.coverage-manifest.json" "$out/.crap-manifest.json" .
chmod u+w .coverage-manifest.json .crap-manifest.json

echo
echo "Regenerated .coverage-manifest.json and .crap-manifest.json from:"
echo "  $out"
echo "Review the diff (git diff -- .coverage-manifest.json .crap-manifest.json)"
echo "and commit both manifests with the change that moved coverage."
