#!/usr/bin/env bash
# Pre-commit gate: run the full `cargo xtask check` (fmt + clippy + the Nix
# coverage/test gate in Fix mode) on every commit, so history stays green
# commit-by-commit — defects are caught at the point of change, when they're
# cheapest, before a buried bad commit forces history-rewriting later.
#
# `check` auto-fixes formatting and auto-heals the coverage baseline / CRAP
# manifest. Those heals are now idempotent on a pure line-shift — the baseline
# compares line-independently (#113) and the CRAP manifest ignores line
# attribution (#7), and benign shifts self-heal via re-anchor (#86) — so `check`
# only changes the tree when there is a REAL fix to apply: a reformat, or a
# genuine coverage/CRAP change. When it does, we fail-and-restage: abort so the
# author consciously `git add`s the change and re-commits, rather than us
# silently folding it into their commit. (This replaces the earlier two-pass
# hack that ran `check --no-test` + `validate` to avoid manifest churn.)
#
# SKIP_PRE_COMMIT=1 bypasses for WIP commits.
set -euo pipefail

if [ "${SKIP_PRE_COMMIT:-0}" = "1" ]; then
    echo "--- pre-commit: SKIP_PRE_COMMIT=1, skipping ---"
    exit 0
fi

echo "--- pre-commit: cargo xtask check (full gate + auto-heal) ---"
pre=$(git status --porcelain)
cargo xtask check
post=$(git status --porcelain)

if [ "$pre" != "$post" ]; then
    echo "--- pre-commit: check applied fixes (formatting and/or coverage artifacts) — review, git add, and re-commit ---" >&2
    exit 1
fi

echo "--- pre-commit: all checks passed ---"
