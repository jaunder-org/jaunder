# Direnv state
/.direnv/

# Generated by Cargo
# will have compiled files and executables
/target/
pkg

# Tool crates live in the tools/ workspace, separate from the app workspace so
# their edits don't bust the app/coverage caches. Ignore any build dir under it;
# tools/Cargo.lock IS committed (devtool is a binary built reproducibly by Nix).
/tools/target/
tools/**/target/

# These are backup files generated by rustfmt
**/*.rs.bk

# node e2e test tools and outputs
node_modules/
test-results/
end2end/playwright-report/
playwright/.cache/

# Various bits of detritus
/result
/data/
.crap-report.json
.coverage-report.lcov
/jaunder-interactive-testing.qcow2
.worktrees/
.coverage-report.json
.coverage-report.txt
mutants.out/
mutants.out.old/

/coverage-report.txt

# xtask sidecar / GC roots — unanchored: `cargo xtask e2e-local` runs as
# cargo-leptos's `end2end-cmd` from `end2end/`, so the sidecar can also land in
# `end2end/.xtask/` (not just the repo root).
.xtask/

# Subagent-driven-development scratch (briefs, ledger, review packages)
/.superpowers/

# ADR drafts live out of git until `cargo xtask adr promote` numbers them at
# ship (see docs/adr/drafts/README.md). Keep the explainer tracked.
docs/adr/drafts/*
!docs/adr/drafts/README.md
