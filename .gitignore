# Direnv state
/.direnv/

# Generated by Cargo
# will have compiled files and executables
/target/
pkg

# Nested tool crates are their own workspaces (kept out of the main workspace
# so their source isn't instrumented by the coverage build). Ignore their build
# dirs. The `coverage` lib's lock is dev-only; `devtool` is a binary whose lock
# IS committed for reproducible in-sandbox Nix builds.
/coverage/target/
/coverage/Cargo.lock
/devtool/target/

# These are backup files generated by rustfmt
**/*.rs.bk

# node e2e test tools and outputs
node_modules/
test-results/
end2end/playwright-report/
playwright/.cache/

# Various bits of detritus
/result
/data/
.crap-report.json
.coverage-report.lcov
/jaunder-interactive-testing.qcow2
.worktrees/
.coverage-report.json
.coverage-report.txt
mutants.out/
mutants.out.old/

/coverage-report.txt

# xtask sidecar / GC roots
/.xtask/
